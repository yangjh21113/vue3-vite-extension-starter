{
  "name": "vite-ts-vue-crx-framework",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:popup": "vite -c vite.popup.config.js",
    "build:popup": "vite build -c vite.popup.config.js && node singleBuild.js popup",
    "dev:content": "vite -c vite.content.config.js",
    "build:content": "vite build -c vite.content.config.js && node singleBuild.js content",
    "build:background": "vite build -c vite.background.config.js && node singleBuild.js background",
    "dev:sidePanel": "vite -c vite.sidePanel.config.js",
    "build:sidePanel": "vite build -c vite.sidePanel.config.js && node singleBuild.js sidePanel",
    "dev:newtab": "vite -c vite.newtab.config.js",
    "build:newtab": "vite build -c vite.newtab.config.js && node singleBuild.js newtab",
    "dev:options": "vite -c vite.options.config.js",
    "build:options": "vite build -c vite.options.config.js && node singleBuild.js options",
    "dev": "concurrently \"pnpm dev:popup\" \"pnpm dev:sidePanel\" \"pnpm dev:newtab\"",
    "icons": "node scripts/generate-icons.mjs",
    "sync-version": "node scripts/sync-manifest-version.mjs",
    "format": "prettier --write \"**/*.{js,cjs,mjs,ts,vue,json,css,scss,html}\" && eslint --fix .",
    "format:check": "prettier --check \"**/*.{js,cjs,mjs,ts,vue,json,css,scss,html}\" && eslint .",
    "typecheck": "vue-tsc --noEmit",
    "build": "node buildAll.js",
    "build:sync": "node buildAll.js sync",
    "prepare": "husky"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "element-plus": "^2.3.9",
    "pinia": "^2.1.7",
    "vue": "^3.3.4",
    "vue-router": "^4.2.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.14.11",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "concurrently": "^9",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.0",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "lint-staged": "^16",
    "prettier": "^3.8.3",
    "sass": "^1.66.1",
    "sharp": "^0.34.5",
    "typescript": "^5.5.3",
    "vite": "^7.0.8",
    "vite-plugin-svg-icons": "^2.0.1",
    "vue-tsc": "^2.0.26"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,vue}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,scss,html}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.12.1"
}
